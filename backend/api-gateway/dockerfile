# =========================
# 1. Base image
# =========================
FROM node:20-slim

WORKDIR /usr/src/app

# =========================
# 2. Install dependencies
# =========================
COPY package*.json ./

# safer than npm ci in unstable networks
RUN npm install --legacy-peer-deps

# =========================
# 3. Copy source code
# =========================
COPY . .

# =========================
# 4. Build TypeScript (if applicable)
# =========================
RUN npm run build

# =========================
# 5. Expose API Gateway port
# =========================
EXPOSE 4000

# =========================
# 6. Start app
# =========================
CMD ["node", "dist/index.js"]
