{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",

    "outDir": "dist",
    "rootDir": "src",

    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,

    "ignoreDeprecations": "6.0"
  },
  "exclude": ["node_modules","prisma.config.ts"]
}