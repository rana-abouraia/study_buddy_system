generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Notification {
  id              String   @id @default(uuid())
  userId          String
  type            String
  title           String
  message         String
  sourceTopic     String
  producerService String?
  correlationId   String?
  isRead          Boolean  @default(false)
  readAt          DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, isRead])
  @@index([sourceTopic])
}
