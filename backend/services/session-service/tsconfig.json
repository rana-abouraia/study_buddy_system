{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",

    "outDir": "dist",
    "rootDir": "src",

    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,

    "ignoreDeprecations": "6.0"
  },
    "include": ["src"],

  "exclude": ["node_modules"]
}