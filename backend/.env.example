JWT_SECRET=replace-with-a-long-random-secret

# Docker Compose internal service URLs
USER_SERVICE_URL=http://user-service:4001/graphql
PROFILE_SERVICE_URL=http://profile-service:4002/graphql
AVAILABILITY_SERVICE_URL=http://availability-service:4003/graphql
MATCHING_SERVICE_URL=http://matching-service:4004/graphql
SESSION_SERVICE_URL=http://session-service:4005/graphql
NOTIFICATION_SERVICE_URL=http://notification-service:4006/graphql
MESSAGING_SERVICE_URL=http://messaging-service:4007/graphql

# Docker Compose Kafka
KAFKA_BROKER=kafka:9092

# Per-service databases
USER_DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
PROFILE_DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
AVAILABILITY_DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
MATCHING_DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
SESSION_DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
NOTIFICATION_DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
MESSAGING_DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
